Algoritmo "semnome"
// 
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 27/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
 popA, popB: real
   taxaA, taxaB: real
   anos: inteiro


Inicio
 popA <- 80000
   popB <- 200000

   taxaA <- 0.03
   taxaB <- 0.015

   anos <- 0

   enquanto (popA <= popB) faca
      popA <- popA + (popA * taxaA)
      popB <- popB + (popB * taxaB)
      anos <- anos + 1
   fimenquanto

   escreval("--- RESULTADO DA SIMULAÇĂO ---")
   escreval("Populaçăo Final A: ", popA:10:0)
   escreval("Populaçăo Final B: ", popB:10:0)
   escreval("Tempo necessário: ", anos, " anos.")
   escreval("------------------------------")


Fimalgoritmo